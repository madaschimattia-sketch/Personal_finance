# Secret edge function IBKR Flex Web Service — configurati in Supabase (Edge Functions → Secrets),
# NON in questo file e MAI committati. Qui solo i nomi richiesti.

# Token del Flex Web Service IBKR (unico per l'utente; NON è il Query ID)
IBKR_FLEX_TOKEN=

# Claude API per il parsing PDF di UTENZE/INTROITI
ANTHROPIC_API_KEY=

# Chiave service_role Supabase (solo lato edge function)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=
